# Ignore node modules and logs
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.local
.env.*.local

# OS generated files
.DS_Store
Thumbs.db

# Logs and temporary folders
logs/
*.log
tmp/

# Editor folders
.vscode/
.idea/

# Coverage/build caches
coverage/
.cache/
dist/

# Ignore local IDE run files
*.sublime-workspace

# Keep all build output (/_next, /images, CNAME, .nojekyll) committed for deployment
!_next/
!images/
!CNAME
!.nojekyll
